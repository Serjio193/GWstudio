{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GW Studio",
  "version": "1.0.2",
  "identifier": "com.gamwatch.gwstudio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GW Studio",
        "width": 1600,
        "height": 1100,
        "minWidth": 1400,
        "minHeight": 900,
        "theme": "Dark",
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/icon.ico"
    ]
  }
}
