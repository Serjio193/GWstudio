{
  "name": "gw-studio-tauri",
  "private": true,
  "version": "1.0.14",
  "license": "Unlicense",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "npm run build && npm run rust:check && npm run rust:test && npm run release:safety",
    "check:full": "npm run check && npm run format:check && npm run lint",
    "format:check": "npm run rust:fmt:check",
    "lint": "npm run rust:clippy",
    "preview": "vite preview",
    "release:safety": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/check-release-safety.ps1",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml --all-targets",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "rust:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "tauri:dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "tauri:build": "tauri build",
    "test": "npm run rust:test"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "clsx": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "vite": "^7.2.1"
  }
}
